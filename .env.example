# ntfy notifications (scripts/notify.sh)
# Bearer token for authenticating to your ntfy server.
NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ntfy server URL — omit to use the public https://ntfy.sh
NTFY_SERVER=https://ntfy.dougie-mo.cc

# ntfy topic to publish to — omit to use the default "agentic-trading"
NTFY_TOPIC=agentic-trading
